---
const { projects = [] } = Astro.props;
---

<section class="projects-preview">
  <div class="projects-header">
    <div>
      <span class="section-label">Réalisations</span>
      <h2 class="section-title">Mes <span class="text-gradient">projets</span> récents</h2>
    </div>
    <a href="/projets" class="btn-outline">
      Voir tout <i class="fa-solid fa-arrow-right"></i>
    </a>
  </div>

  {projects.length > 0 ? (
    <div class="projects-masonry">
      {projects.slice(0, 5).map((p, i) => (
        <a
          href={p.data.url || '#'}
          target={p.data.url ? '_blank' : ''}
          class="project-card reveal"
          style="transition-delay: {0.1 * i}s"
        >
          <div class="project-img">
            <img src={p.data.image || '/images/placeholder.svg'} alt={p.data.titre} loading="lazy" />
            <div class="project-overlay">
              <span>Voir <i class="fa-solid fa-arrow-up-right"></i></span>
            </div>
          </div>
          <div class="project-info">
            <span class="project-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{p.data.titre}</h3>
            <div class="project-techs">
              {(p.data.technologies || []).slice(0, 3).map(t => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <p>Ajoutez vos projets depuis le <a href="/keystatic" style="color: var(--brand);">panel admin</a></p>
    </div>
  )}
</section>

<style>
  .projects-preview {
    padding: 100px 80px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .projects-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 50px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .projects-masonry {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
  }
  .projects-masonry .project-card:first-child {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }
  .project-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--surface);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.5s;
    border: 1px solid rgba(255,255,255,0.04);
  }
  .project-card:hover {
    transform: translateY(-6px);
    border-color: rgba(189, 56, 8, 0.2);
    box-shadow: 0 20px 60px rgba(189, 56, 8, 0.08);
  }
  .project-img {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: #111;
  }
  .projects-masonry .project-card:first-child .project-img { aspect-ratio: 16 / 9; }
  .project-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s;
  }
  .project-card:hover .project-img img { transform: scale(1.06); }
  .project-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(189, 56, 8, 0.4), transparent);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.4s;
  }
  .project-card:hover .project-overlay { opacity: 1; }
  .project-overlay span {
    background: var(--brand);
    color: #fff;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .project-info { padding: 20px; }
  .project-num {
    font-family: 'Playfair Display', serif;
    font-size: 0.75rem;
    color: var(--brand);
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .project-info h3 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.1rem;
    margin: 6px 0 10px;
  }
  .project-techs { display: flex; gap: 6px; flex-wrap: wrap; }
  .tech-tag {
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 20px;
    background: rgba(255,255,255,0.06);
    color: var(--muted);
    font-weight: 600;
  }
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px 20px;
    color: var(--muted);
  }

  @media (max-width: 992px) {
    .projects-preview { padding: 60px 24px; }
    .projects-masonry { grid-template-columns: 1fr 1fr; }
    .projects-masonry .project-card:first-child {
      grid-column: 1 / -1;
      grid-row: auto;
    }
  }
  @media (max-width: 576px) {
    .projects-masonry { grid-template-columns: 1fr; }
  }
</style>

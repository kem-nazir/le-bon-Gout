---
const { posts = [] } = Astro.props;
const latest = posts.slice(0, 3);
---

<section class="blog-preview">
  <div class="blog-header">
    <div>
      <span class="section-label">Blog</span>
      <h2 class="section-title">Dernières <span class="text-gradient">actualités</span></h2>
    </div>
    <a href="/blog" class="btn-outline">
      Tous les articles <i class="fa-solid fa-arrow-right"></i>
    </a>
  </div>
  <div class="blog-grid">
    {latest.length > 0 ? latest.map((post, i) => (
      <a href={`/blog/${post.slug}`} class="blog-card reveal" style="transition-delay: {0.1 * i}s">
        <div class="blog-img">
          <img src={post.data.couverture || '/images/placeholder.svg'} alt={post.data.titre} loading="lazy" />
          {post.data.categorie && <span class="blog-cat">{post.data.categorie}</span>}
        </div>
        <div class="blog-body">
          <span class="blog-date"><i class="fa-regular fa-calendar"></i> {post.data.date || ''}</span>
          <h3>{post.data.titre}</h3>
          {post.data.extrait && <p>{post.data.extrait}</p>}
          <span class="blog-link">Lire <i class="fa-solid fa-arrow-right"></i></span>
        </div>
      </a>
    )) : (
      <div class="empty-state">
        <p>Pas encore d'articles. <a href="/keystatic" style="color: var(--brand);">Écrivez-en un</a></p>
      </div>
    )}
  </div>
</section>

<style>
  .blog-preview {
    padding: 100px 80px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .blog-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 50px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--surface);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.04);
    transition: all 0.4s;
  }
  .blog-card:hover {
    transform: translateY(-6px);
    border-color: rgba(189, 56, 8, 0.2);
    box-shadow: 0 20px 60px rgba(189, 56, 8, 0.08);
  }
  .blog-img {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: #111;
  }
  .blog-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .blog-card:hover .blog-img img { transform: scale(1.06); }
  .blog-cat {
    position: absolute;
    top: 14px;
    left: 14px;
    background: var(--brand);
    color: #fff;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .blog-body { padding: 20px 22px; }
  .blog-date { font-size: 0.8rem; color: var(--muted); display: flex; align-items: center; gap: 6px; margin-bottom: 10px; }
  .blog-body h3 { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.1rem; margin-bottom: 8px; }
  .blog-body p { color: var(--muted); font-size: 0.85rem; line-height: 1.6; margin-bottom: 14px; }
  .blog-link { font-size: 0.85rem; color: var(--text); display: inline-flex; align-items: center; gap: 6px; transition: gap 0.3s; }
  .blog-card:hover .blog-link { gap: 10px; color: var(--brand); }
  .empty-state { grid-column: 1/-1; text-align: center; padding: 60px; color: var(--muted); }

  @media (max-width: 768px) {
    .blog-preview { padding: 60px 24px; }
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---

<Layout title="À Propos — Rachad Développement Web">
  <Header />
  <main class="page-main">
    <!-- Hero -->
    <section class="about-hero">
      <div class="about-hero-grid">
        <div class="about-hero-text">
          <span class="reveal section-label">À propos</span>
          <h1 class="reveal about-hero-title" style="transition-delay: 0.1s">
            Passionné par le web,<br/>au service de votre <span class="text-gradient">commerce</span>
          </h1>
          <p class="reveal" style="transition-delay: 0.2s; color: var(--muted); line-height: 1.8;">
            Depuis plusieurs années, j'accompagne les commerçants et artisans
            à développer leur présence en ligne avec des sites modernes,
            rapides et faciles à gérer.
          </p>
        </div>
        <div class="about-visual reveal" style="transition-delay: 0.2s">
          <div class="about-geo">
            <div class="geo-c geo-1"></div>
            <div class="geo-c geo-2"></div>
            <div class="geo-c geo-3"></div>
          </div>
          <div class="about-photo">
            <div class="photo-placeholder">
              <i class="fa-solid fa-user"></i>
              <span>Votre photo</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats-bar reveal">
      <div class="stat-item">
        <strong data-count="20">0</strong>
        <span>Projets</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <strong data-count="15">0</strong>
        <span>Clients</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <strong data-count="5">0</strong>
        <span>Années</span>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <strong data-count="100">0</strong>
        <span>% Satisfait</span>
      </div>
    </section>

    <!-- Timeline -->
    <section class="timeline">
      <h2 class="section-title" style="text-align: center; margin-bottom: 60px;">
        Mon <span class="text-gradient">parcours</span>
      </h2>
      <div class="timeline-line">
        <div class="tl-item reveal-left">
          <div class="tl-dot"></div>
          <div class="tl-card">
            <span class="tl-date">2024 — Aujourd'hui</span>
            <h4>Développeur Web Freelance</h4>
            <span class="tl-place">Indépendant — Cotonou</span>
            <p>Création de sites web pour commerces locaux. Accompagnement complet.</p>
          </div>
        </div>
        <div class="tl-item tl-right reveal-right">
          <div class="tl-dot"></div>
          <div class="tl-card">
            <span class="tl-date">2022 — 2024</span>
            <h4>Licence Développement Web</h4>
            <span class="tl-place">Formation continue</span>
            <p>Spécialisation technologies web modernes, architecture et UX.</p>
          </div>
        </div>
        <div class="tl-item reveal-left">
          <div class="tl-dot"></div>
          <div class="tl-card">
            <span class="tl-date">2021 — 2022</span>
            <h4>Développeur Junior</h4>
            <span class="tl-place">Agence Digitale — Cotonou</span>
            <p>Intégration, WordPress, SEO, maintenance de sites.</p>
          </div>
        </div>
        <div class="tl-item tl-right reveal-right">
          <div class="tl-dot"></div>
          <div class="tl-card">
            <span class="tl-date">2020 — 2021</span>
            <h4>Formation intensive</h4>
            <span class="tl-place">Auto-didacte & Bootcamp</span>
            <p>HTML, CSS, JavaScript, React, Node.js.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="skills-section">
      <div class="skills-inner">
        <span class="section-label">Compétences</span>
        <h2 class="section-title">Technologies & <span class="text-gradient">expertises</span></h2>
        <div class="skills-grid">
          {[
            { label: 'IA & Automatisation', pct: 85 },
            { label: 'Frontend (Astro, React)', pct: 95 },
            { label: 'No-Code & CMS', pct: 90 },
            { label: 'UI/UX Design', pct: 80 },
            { label: 'Backend & APIs', pct: 75 },
            { label: 'SEO & Performance', pct: 85 },
          ].map((s, i) => (
            <div class="skill-card reveal" style="transition-delay: {0.1 * i}s">
              <div class="skill-header">
                <span>{s.label}</span>
                <span class="skill-pct">{s.pct}%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style="width: 0%;" data-width={s.pct}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tools -->
    <section class="tools-section">
      <h2 class="section-title" style="text-align: center; margin-bottom: 50px;">
        Ma <span class="text-gradient">stack</span> technique
      </h2>
      <div class="tools-grid">
        {['JavaScript', 'React', 'Python', 'Node.js', 'Tailwind', 'Astro', 'GitHub', 'Figma', 'Supabase', 'Vercel'].map((t, i) => (
          <div class="tool-item reveal" style="transition-delay: {0.05 * i}s">
            <span>{t}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="about-cta">
      <div class="cta-inner">
        <h2>Envie de travailler <span class="text-gradient">ensemble</span> ?</h2>
        <p>Discutons de votre projet sans engagement.</p>
        <div class="cta-btns">
          <a href="https://wa.me/22966153442" class="cta-btn" target="_blank">
            <i class="fa-brands fa-whatsapp"></i> Contactez-moi
          </a>
          <a href="/contact" class="cta-btn-outline">
            <i class="fa-regular fa-envelope"></i> Formulaire
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  .page-main { padding-top: 100px; }

  .about-hero {
    padding: 40px 80px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 60px;
  }
  .about-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 16px 0 20px;
  }
  .about-visual { position: relative; display: flex; justify-content: center; align-items: center; min-height: 400px; }
  .about-geo { position: absolute; }
  .geo-c {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(189, 56, 8, 0.12);
  }
  .geo-1 { width: 350px; height: 350px; top: -30px; left: -30px; }
  .geo-2 { width: 280px; height: 280px; top: 5px; left: 5px; }
  .geo-3 { width: 210px; height: 210px; top: 40px; left: 40px; background: rgba(189, 56, 8, 0.03); }
  .about-photo { position: relative; z-index: 2; }
  .photo-placeholder {
    width: 220px; height: 220px;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid rgba(189, 56, 8, 0.2);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 8px; color: var(--muted); font-size: 0.85rem;
  }
  .photo-placeholder i { font-size: 2.5rem; color: var(--brand); }

  .stats-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    padding: 50px 20px;
    background: var(--surface);
    margin: 80px 0;
  }
  .stat-item { text-align: center; padding: 0 60px; }
  .stat-item strong {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    color: var(--brand);
    display: block;
  }
  .stat-item span { font-size: 0.82rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .stat-div { width: 1px; height: 40px; background: rgba(255,255,255,0.06); }

  .timeline { padding: 80px 80px 120px; max-width: 900px; margin: 0 auto; }
  .timeline-line { position: relative; }
  .timeline-line::before {
    content: '';
    position: absolute; left: 50%; top: 0; bottom: 0;
    width: 1px; background: rgba(189, 56, 8, 0.2);
    transform: translateX(-50%);
  }
  .tl-item {
    display: flex; width: 50%;
    padding: 0 40px 40px 0; position: relative;
  }
  .tl-item.tl-right { margin-left: 50%; padding: 0 0 40px 40px; }
  .tl-dot {
    position: absolute; top: 16px;
    width: 12px; height: 12px;
    background: var(--brand); border-radius: 50%;
    right: -6px; z-index: 2;
    box-shadow: 0 0 0 4px rgba(189, 56, 8, 0.15);
  }
  .tl-item.tl-right .tl-dot { left: -6px; right: auto; }
  .tl-card {
    background: var(--surface);
    border-radius: 12px;
    padding: 20px 24px;
    width: 100%;
    border: 1px solid rgba(255,255,255,0.04);
  }
  .tl-date { font-size: 0.78rem; color: var(--brand); font-weight: 600; margin-bottom: 6px; display: block; }
  .tl-card h4 { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
  .tl-place { font-size: 0.8rem; color: var(--muted); display: block; margin-bottom: 8px; }
  .tl-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.6; margin: 0; }

  .skills-section { padding: 80px; background: var(--surface); }
  .skills-inner { max-width: 800px; margin: 0 auto; }
  .skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px; }
  .skill-card { background: var(--bg); border-radius: 12px; padding: 20px; border: 1px solid rgba(255,255,255,0.04); }
  .skill-header { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.9rem; font-weight: 600; }
  .skill-pct { color: var(--brand); }
  .skill-bar { height: 6px; background: rgba(255,255,255,0.06); border-radius: 10px; overflow: hidden; }
  .skill-fill { height: 100%; background: var(--brand); border-radius: 10px; transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1); }

  .tools-section { padding: 100px 80px; max-width: 1400px; margin: 0 auto; }
  .tools-grid { display: flex; justify-content: center; flex-wrap: wrap; gap: 12px; }
  .tool-item {
    padding: 14px 28px;
    background: var(--surface);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.04);
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s;
    cursor: default;
  }
  .tool-item:hover { border-color: rgba(189, 56, 8, 0.3); background: rgba(189, 56, 8, 0.05); }

  .about-cta { padding: 0 80px 100px; max-width: 1400px; margin: 0 auto; }
  .about-cta .cta-inner {
    background: linear-gradient(135deg, #1a1a1a, #0a0a0a);
    border: 1px solid rgba(189, 56, 8, 0.15);
    border-radius: 24px; padding: 70px 60px;
    text-align: center;
  }
  .about-cta h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700; margin-bottom: 12px;
  }
  .about-cta p { color: var(--muted); margin-bottom: 36px; }
  .cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .cta-btn {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--brand); color: #fff; font-weight: 700;
    border-radius: 10px; padding: 14px 30px; text-decoration: none;
    transition: all 0.3s;
  }
  .cta-btn:hover { box-shadow: 0 0 30px rgba(189, 56, 8, 0.4); transform: translateY(-2px); color: #fff; }
  .cta-btn-outline {
    display: inline-flex; align-items: center; gap: 10px;
    border: 1.5px solid rgba(255,255,255,0.2); color: var(--text);
    font-weight: 600; border-radius: 10px; padding: 14px 30px;
    text-decoration: none; transition: all 0.3s;
  }
  .cta-btn-outline:hover { border-color: var(--brand); color: var(--brand); }

  @media (max-width: 992px) {
    .about-hero { padding: 40px 24px; }
    .about-hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-visual { min-height: 300px; }
    .stats-bar { flex-wrap: wrap; gap: 20px; margin: 40px 0; }
    .stat-item { padding: 16px 32px; }
    .stat-div { display: none; }
    .timeline { padding: 60px 24px; }
    .timeline-line::before { left: 16px; }
    .tl-item, .tl-item.tl-right { width: 100%; margin-left: 0; padding: 0 0 30px 40px; }
    .tl-dot, .tl-item.tl-right .tl-dot { left: 10px; right: auto; }
    .skills-section { padding: 60px 24px; }
    .skills-grid { grid-template-columns: 1fr; }
    .tools-section { padding: 60px 24px; }
    .about-cta { padding: 0 24px 60px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const fill = entry.target;
          fill.style.width = fill.dataset.width + '%';
          obs.unobserve(fill);
        }
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.skill-fill').forEach(el => obs.observe(el));
  });
</script>

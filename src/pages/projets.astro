---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

const projects = await getCollection('projects');
const categories = ['tous', 'vitrine', 'ecommerce', 'onepage', 'webapp'];
---

<Layout title="Mes Projets — Rachad Développement Web">
  <Header />
  <main class="page-main">
    <section class="page-hero">
      <span class="reveal section-label">Portfolio</span>
      <h1 class="reveal page-hero-title" style="transition-delay: 0.1s">
        Mes <span class="text-gradient">réalisations</span>
      </h1>
      <p class="reveal page-hero-sub" style="transition-delay: 0.2s">
        {projects.length} projets livrés avec passion
      </p>

      <div class="filter-bar reveal" style="transition-delay: 0.3s">
        {categories.map(cat => (
          <button class="filter-btn" data-filter={cat}>
            {cat === 'tous' ? 'Tous' : cat.charAt(0).toUpperCase() + cat.slice(1)}
          </button>
        ))}
      </div>
    </section>

    <section class="page-content">
      <div class="projects-grid" id="projectsGrid">
        {projects.length > 0 ? projects.map((p, i) => (
          <a
            href={p.data.url || '#'}
            target={p.data.url ? '_blank' : ''}
            class="project-card reveal"
            style="transition-delay: {0.05 * i}s"
            data-category={p.data.categorie || 'vitrine'}
          >
            <div class="project-img">
              <img src={p.data.image || '/images/placeholder.svg'} alt={p.data.titre} loading="lazy" />
              <div class="overlay"><span>Voir <i class="fa-solid fa-arrow-up-right"></i></span></div>
              <div class="project-num">{String(i + 1).padStart(2, '0')}</div>
            </div>
            <div class="project-info">
              <h3>{p.data.titre}</h3>
              <p>{p.data.description}</p>
              {(p.data.technologies || []).length > 0 && (
                <div class="techs">
                  {p.data.technologies.slice(0, 4).map(t => <span>{t}</span>)}
                </div>
              )}
            </div>
          </a>
        )) : (
          <div class="empty-state">
            <p>Ajoutez vos projets dans le <a href="/keystatic" style="color: var(--brand);">panel admin</a></p>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  .page-main { padding-top: 100px; }
  .page-hero {
    text-align: center;
    padding: 60px 24px 40px;
    max-width: 800px;
    margin: 0 auto;
  }
  .page-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 700;
    margin: 16px 0;
  }
  .page-hero-sub { color: var(--muted); font-size: 1rem; }

  .filter-bar {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 40px;
  }
  .filter-btn {
    padding: 8px 20px;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid rgba(255,255,255,0.06);
    color: var(--muted);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.3s;
  }
  .filter-btn:hover, .filter-btn.active { background: var(--brand); color: #fff; border-color: var(--brand); }

  .page-content {
    padding: 40px 80px 100px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .project-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--surface);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.04);
    transition: all 0.5s;
  }
  .project-card:hover {
    transform: translateY(-6px);
    border-color: rgba(189, 56, 8, 0.2);
    box-shadow: 0 20px 60px rgba(189, 56, 8, 0.08);
  }
  .project-img {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #111;
  }
  .project-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .project-card:hover .project-img img { transform: scale(1.06); }
  .overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(189, 56, 8, 0.35), transparent);
    display: flex; align-items: flex-end; padding: 16px;
    opacity: 0; transition: opacity 0.4s;
  }
  .project-card:hover .overlay { opacity: 1; }
  .overlay span {
    background: var(--brand); color: #fff; padding: 8px 16px;
    border-radius: 6px; font-weight: 600; font-size: 0.82rem;
    display: flex; align-items: center; gap: 6px;
  }
  .project-num {
    position: absolute; top: 12px; left: 12px;
    font-family: 'Playfair Display', serif;
    font-size: 0.75rem; color: rgba(255,255,255,0.5);
    font-weight: 700; background: rgba(0,0,0,0.5);
    padding: 4px 10px; border-radius: 6px;
  }
  .project-info { padding: 20px; }
  .project-info h3 { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.05rem; margin-bottom: 8px; }
  .project-info p { color: var(--muted); font-size: 0.84rem; line-height: 1.6; margin-bottom: 12px; }
  .techs { display: flex; gap: 6px; flex-wrap: wrap; }
  .techs span {
    font-size: 0.7rem; padding: 3px 10px;
    border-radius: 20px; background: rgba(255,255,255,0.06);
    color: var(--muted); font-weight: 600;
  }
  .empty-state { grid-column: 1/-1; text-align: center; padding: 80px; color: var(--muted); }

  @media (max-width: 992px) {
    .page-content { padding: 40px 24px 60px; }
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 576px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const f = btn.dataset.filter;
      document.querySelectorAll('.project-card').forEach(c => {
        c.style.display = f === 'tous' || c.dataset.category === f ? 'block' : 'none';
      });
    });
  });
  document.querySelector('.filter-btn')?.classList.add('active');
</script>
